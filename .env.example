# Vercel Environment Variables
# Thêm vào Vercel Dashboard → Settings → Environment Variables

# Groq API
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_DEFAULT_MODEL=openai/gpt-oss-120b

# Gemini API
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Groq API Key (đặt trong Vercel Environment Variables, không để trong code)
# GROQ_API_KEY=your_gsk_xxx_key

# Gemini API Key (đặt trong Vercel Environment Variables, không để trong code)
# GEMINI_API_KEY=your_AIza_xxx_key

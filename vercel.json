{
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "bun run build"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/sitemap",
      "destination": "/api/sitemap.js"
    },
    {
      "source": "/api/ai",
      "destination": "/api/ai.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ]
}
